# .gitignore
# Large data — not tracked in git
*.fastq
*.fastq.gz
*.fa
*.fasta
*.fna
data/fastas/
data/reports/
cleaned_data/
kraken_db_standard/

# Large binary outputs
*.npy
*.zip

# Pipeline results (regenerable)
project_out/

# Build / IDE artefacts
*.log
*.html
__pycache__/
*.pyc
.ipynb_checkpoints/
