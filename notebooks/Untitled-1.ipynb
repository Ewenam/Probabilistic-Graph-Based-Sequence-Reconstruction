   "source": [
    "import numpy as np\n",
    "A = np.loadtxt(\"AAB Project/project_out/pipeline_results_genus_loose/graph_adjacency.csv\", delimiter=\",\")\n",
    "n = A.shape[0]\n",
    "density = A.sum() / (n*(n-1))\n",
    "print(f\"Graph density = {density:.4f} ({A.sum()} edges among {n} nodes)\")\n"
   ]
  }
